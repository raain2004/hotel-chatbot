# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hotel_chatbot

# Claude AI
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024

# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_VERIFY_TOKEN=your_custom_verify_token
FB_APP_SECRET=your_app_secret
FB_GRAPH_API_VERSION=v21.0

# App
APP_ENV=development
SECRET_KEY=your_secret_key_here

# Admin dashboard (header X-Admin-Key)
ADMIN_API_KEY=your_admin_key_here

# Webhook thông báo Slack/Discord (tùy chọn)
NOTIFY_WEBHOOK_URL=

# Test — mock Claude, không gọi API thật
CLAUDE_MOCK_MODE=false
